{
  "name": "custodian",
  "version": "1.0.0",
  "description": "A Discord bot for message cleanup and management — runs 100% free on Cloudflare Workers + D1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "db:migrate:local": "wrangler d1 execute custodian_db --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute custodian_db --remote --file=./schema.sql",
    "register-commands": "node deploy-commands.js"
  },
  "keywords": [
    "discord",
    "bot",
    "cleanup",
    "moderation",
    "cloudflare-workers"
  ],
  "author": "ShibbityShwab",
  "license": "ISC",
  "dependencies": {
    "@discordjs/rest": "^2.4.0",
    "discord-api-types": "^0.37.97",
    "discord-interactions": "^4.4.0",
    "hono": "^4.12.15"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "vitest": "^3.2.0",
    "wrangler": "^4.85.0"
  }
}
