{
  "name": "custodian",
  "version": "1.0.0",
  "description": "A Discord bot for message cleanup and management",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "dev": "nodemon index.js",
    "start": "node index.js",
    "prepare": "husky install"
  },
  "keywords": [
    "discord",
    "bot",
    "cleanup",
    "moderation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "discord-interactions": "^4.4.0",
    "discord.js": "^14.14.1",
    "hono": "^4.12.15"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.1",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "vitest": "^1.6.1",
    "wrangler": "^4.85.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
